# WisprAlt server environment variables
# chmod 600 after population
# Copy this file to .env and fill in real values before starting the server.

HF_TOKEN=
WISPRALT_API_KEY=
SERVER_URL=
MEETING_OUTPUT_DIR=
JOB_DB_PATH=
STAGING_DIR=
SILENCE_THRESHOLD=0.002
MAX_UPLOAD_BYTES=2147483648

# Rate limits (M6) — requests per rolling window, per real client IP.
# Rate limits use CF-Connecting-IP (Cloudflare Tunnel) for real-IP extraction.
DICTATE_RATE_PER_MIN=60
MEETING_RATE_PER_HOUR=4

# Idle-eviction for meeting models. After this many seconds with no meeting
# activity (no submission, no in-flight job), the server unloads WhisperX +
# Pyannote to reclaim ~3 GB python RSS. Next meeting pays a 5-30s cold-load
# cost. Set to 0 to disable (models stay warm forever).
MEETING_IDLE_EVICTION_SECONDS=60

# Hard cap on dictation audio length (post-resample, in seconds). Defends
# against decode-amplification (1KB body decoding to many minutes) and
# single-thread executor starvation. Default 300s = 5 min covers natural
# long-form hold-FN dictations. For longer audio, use meeting recording.
DICTATION_MAX_DURATION_S=300

# Set to false if exposing FastAPI directly without Cloudflare Tunnel (e.g. LAN testing)
# to avoid IP spoofing in rate limiting. When true, CF-Connecting-IP is trusted.
TRUST_FORWARDED_HEADERS=true

# Supabase Postgres connection URL (chmod 600 the .env file containing this).
# Optional — if blank, the server runs in break-glass-only mode and the
# multi-tenant auth + usage event tracking are disabled.  Format:
# postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
SUPABASE_DATABASE_URL=

# Optional: enable smart formatting via OpenRouter Mercury 2.
# Get a key at https://openrouter.ai/keys. Costs ~$0.0001 per dictation cleanup.
# Leave unset to disable smart formatting (clients toggling it on will silently get raw text).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=inception/mercury-2
# 1500 ms covers cross-region OpenRouter calls + TLS handshake. 250 ms is too tight
# and causes silent fall-through to raw on cold connections.
OPENROUTER_TIMEOUT_MS=1500
