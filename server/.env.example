# WisprAlt server environment variables
# chmod 600 after population
# Copy this file to .env and fill in real values before starting the server.

HF_TOKEN=
WISPRALT_API_KEY=
SERVER_URL=
MEETING_OUTPUT_DIR=
JOB_DB_PATH=
STAGING_DIR=
SILENCE_THRESHOLD=0.002
MAX_UPLOAD_BYTES=2147483648

# Rate limits (M6) — requests per rolling window, per real client IP.
# Rate limits use CF-Connecting-IP (Cloudflare Tunnel) for real-IP extraction.
DICTATE_RATE_PER_MIN=60
MEETING_RATE_PER_HOUR=4

# Set to false if exposing FastAPI directly without Cloudflare Tunnel (e.g. LAN testing)
# to avoid IP spoofing in rate limiting. When true, CF-Connecting-IP is trusted.
TRUST_FORWARDED_HEADERS=true
