{% extends "base.html.j2" %}
{% set TAB_LABELS = {'today': 'Today', '7d': '7d', '30d': '30d', '90d': '90d', '1y': '1y', 'all': 'All'} %}
{% block title %}Data · Wispralt{% endblock %}
{% block content %}
<div class="data-page">
  <h2>
    Data — ISO {{ iso_year }}-W{{ "%02d" | format(iso_week) }}
    {% if target_user %}— {{ target_user.label }}{% endif %}
  </h2>

  <nav x-data="{ active: '{{ range }}' }"
       @range-changed.window="active = $event.detail"
       class="range-tabs">
    {% for r in ['today', '7d', '30d', '90d', '1y', 'all'] %}
      <button :class="active === '{{ r }}' ? 'active' : ''"
              @click="active = '{{ r }}'"
              hx-get="/admin/data?range={{ r }}{% if user_id %}&user_id={{ user_id }}{% endif %}"
              hx-target="#insights-body"
              hx-swap="innerHTML"
              hx-push-url="true">
        {{ TAB_LABELS[r] }}
      </button>
    {% endfor %}
  </nav>

  <div id="insights-body">
    {% include "_admin_data_body.html.j2" %}
  </div>
</div>
{% endblock %}
