<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Wispralt Admin{% endblock %}</title>
  <style>
    :root {
      --bg: #fafafa;
      --panel: #ffffff;
      --ink: #1a1a1a;
      --muted: #6b6b6b;
      --line: #e5e5e5;
      --accent: #2b6cb0;
      --bar: #2b6cb0;
      --warn: #c05621;
      --bad: #c53030;
      /* Phase 2 — Apple-liquid glass card vars */
      --glass-bg: rgba(255, 255, 255, 0.04);
      --glass-bg-strong: rgba(255, 255, 255, 0.06);
      --glass-blur: 20px;
      --radius-card: 14px;
      --shadow-card: 0 1px 0 rgba(255,255,255,0.04) inset, 0 4px 16px rgba(0,0,0,0.04);
      --accent-soft: rgba(43, 108, 176, 0.12);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 14px;
      color: var(--ink);
      background: var(--bg);
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    header {
      background: var(--panel);
      border-bottom: 1px solid var(--line);
      padding: 12px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    header h1 { margin: 0; font-size: 16px; font-weight: 600; }
    header .who { color: var(--muted); font-size: 13px; }
    .layout { display: grid; grid-template-columns: 200px 1fr; min-height: calc(100vh - 49px); }
    nav.sidebar {
      background: var(--panel);
      border-right: 1px solid var(--line);
      padding: 16px 0;
    }
    nav.sidebar a {
      display: block;
      padding: 8px 24px;
      color: var(--ink);
    }
    nav.sidebar a:hover { background: var(--bg); text-decoration: none; }
    main { padding: 24px; }
    h2 { margin-top: 0; font-size: 18px; }
    .tiles { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; margin-bottom: 24px; }
    .tile {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 12px 16px;
    }
    .tile .label { color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em; }
    .tile .value { font-size: 22px; font-weight: 600; margin-top: 4px; }
    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 6px;
      overflow: hidden;
      margin-bottom: 24px;
    }
    th, td { text-align: left; padding: 8px 12px; border-bottom: 1px solid var(--line); }
    th { background: var(--bg); font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em; color: var(--muted); }
    tr:last-child td { border-bottom: none; }
    td.bar { width: 50%; }
    td.bar > div {
      height: 12px;
      background: var(--bar);
      border-radius: 2px;
      min-width: 1px;
    }
    form.inline { display: inline; }
    button, input[type="submit"] {
      font: inherit;
      padding: 6px 12px;
      border: 1px solid var(--line);
      background: var(--panel);
      border-radius: 4px;
      cursor: pointer;
    }
    button:hover { background: var(--bg); }
    button.danger { color: var(--bad); border-color: var(--bad); }
    input[type="text"], input[type="password"], input[type="number"], input[type="datetime-local"], select {
      font: inherit;
      padding: 6px 10px;
      border: 1px solid var(--line);
      border-radius: 4px;
      background: var(--panel);
    }
    .filters { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
    .error { color: var(--bad); margin-bottom: 12px; }
    .warn { color: var(--warn); }
    code.token {
      display: block;
      font-size: 14px;
      padding: 12px;
      background: #1a1a1a;
      color: #f5f5f5;
      border-radius: 6px;
      word-break: break-all;
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    }
    .login-card {
      max-width: 360px;
      margin: 64px auto;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 24px;
    }
    .login-card h2 { margin-top: 0; }
    .login-card label { display: block; margin: 12px 0 4px; font-size: 13px; color: var(--muted); }
    .login-card input { width: 100%; }
    .login-card button { margin-top: 16px; width: 100%; background: var(--accent); color: #fff; border-color: var(--accent); }
    .login-card button:hover { filter: brightness(0.95); }
    nav.sidebar a.active { background: var(--accent-soft); color: var(--accent); }
    /* Phase 2 — scoped under .data-page so legacy /admin/overview etc. stay unchanged */
    .data-page .glass-card {
      background: var(--glass-bg-strong);
      backdrop-filter: blur(var(--glass-blur));
      -webkit-backdrop-filter: blur(var(--glass-blur));
      border: 1px solid var(--line);
      border-radius: var(--radius-card);
      box-shadow: var(--shadow-card);
      padding: 18px 20px;
      margin-bottom: 16px;
    }
    @supports not (backdrop-filter: blur(20px)) {
      .data-page .glass-card { background: var(--panel); }
    }
    .data-page h3 { margin: 0 0 12px 0; font-size: 14px; font-weight: 600; }
    .data-page .muted { color: var(--muted); font-size: 13px; }
    .data-page .range-tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 16px;
      padding: 4px;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 10px;
      width: fit-content;
    }
    .data-page .range-tabs button {
      background: transparent;
      border: 1px solid transparent;
      color: var(--muted);
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 13px;
    }
    .data-page .range-tabs button.active {
      background: var(--accent-soft);
      color: var(--accent);
      border-color: var(--accent-soft);
    }
    .data-page .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin-bottom: 16px;
    }
    .data-page .stat-tile {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: var(--radius-card);
      padding: 14px 16px;
    }
    .data-page .stat-tile .label {
      color: var(--muted);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .data-page .stat-tile .value {
      font-size: 24px;
      font-weight: 600;
      margin-top: 4px;
    }
    .data-page .action-list { list-style: none; padding: 0; margin: 0; }
    .data-page .action-list li { padding: 6px 0; border-bottom: 1px solid var(--line); }
    .data-page .action-list li:last-child { border-bottom: none; }
    .data-page .action-list li .eta { color: var(--muted); margin-left: 6px; font-size: 12px; }
    .data-page .ai-disclaimer { color: var(--muted); font-size: 12px; margin: 8px 0 16px 0; font-style: italic; }
    .data-page blockquote.quotable {
      font-size: 16px;
      font-style: italic;
      margin: 0;
      padding-left: 12px;
      border-left: 3px solid var(--accent);
    }
    .data-page .leaderboard-row { display: flex; justify-content: space-between; padding: 4px 0; }
  </style>
  <script src="/admin/static/htmx.min.js" defer
          integrity="sha256-4gndpcgjVHnzFm3vx3UOHbzVpcGAi3eS/C5nM3aPtEc="
          crossorigin="anonymous"></script>
  <script src="/admin/static/alpine.min.js" defer
          integrity="sha256-tgDjY9mdlURNtUrL+y3v/smueSqpmgkim82geOW1VkM="
          crossorigin="anonymous"></script>
  <script defer>
    // Sync the .range-tabs active state with the URL on browser back/forward.
    // HTMX pushes history but doesn't re-init Alpine, so tabs can lie about
    // which range is active when the user navigates. Dispatch a custom event
    // that each <nav x-data> listens for — stable across Alpine 3.x versions.
    // setTimeout(0) defers the dispatch until after Alpine re-initializes
    // x-data on the HTMX-restored DOM; without it, the event fires against
    // a stale instance and the active-tab pip stays at the original render.
    document.addEventListener("htmx:historyRestore", () => {
      const params = new URLSearchParams(window.location.search);
      const range = params.get("range") || "7d";
      setTimeout(() => {
        // Alpine's :class is non-destructive — it won't strip stale "active"
        // classes baked into the cached snapshot. Scrub them before dispatching
        // so the new state is the only one visible.
        document.querySelectorAll(".range-tabs button.active").forEach((b) => {
          b.classList.remove("active");
        });
        window.dispatchEvent(new CustomEvent("range-changed", { detail: range }));
      }, 0);
    });
  </script>
</head>
<body>
  {% if not hide_chrome %}
  <header>
    {% set _is_admin = request.state.user is defined and request.state.user and request.state.user.role == "admin" %}
    <h1>{% if _is_admin %}Wispralt Admin{% else %}Wispralt Portal{% endif %}</h1>
    <span class="who">{% if request.state.user is defined and request.state.user %}{{ request.state.user.label }} ({{ request.state.user.role }}){% endif %}</span>
  </header>
  <div class="layout">
    <nav class="sidebar">
      {% if _is_admin %}
      <a href="/admin/">Overview</a>
      <a href="/admin/users">Users</a>
      <a href="/admin/usage">Usage</a>
      <a href="/admin/data" class="{% if request.url.path.startswith('/admin/data') %}active{% endif %}">Data</a>
      {% else %}
      <a href="/admin/me">My Usage</a>
      <a href="/me/insights" class="{% if request.url.path.startswith('/me/insights') %}active{% endif %}">My Insights</a>
      <a href="/me/history" class="{% if request.url.path.startswith('/me/history') %}active{% endif %}">My History</a>
      {# Plan 2 will add: <a href="/me/profile" ...>My Profile</a> #}
      {% endif %}
    </nav>
    <main>
      {% block content %}{% endblock %}
    </main>
  </div>
  {% else %}
    {% block bare_content %}{% endblock %}
  {% endif %}
</body>
</html>
