{% extends "base.html.j2" %}
{% block title %}Sign in to your insights · Wispralt{% endblock %}
{% block bare_content %}
<div class="login-card">
  <h2>Sign in</h2>
  <p style="margin-top: 0; color: var(--muted); font-size: 13px;">Sign in to view your insights. Paste your WisprAlt token below.</p>
  {% if error %}<p class="error">{{ error }}</p>{% endif %}
  <form method="post" action="/me/login">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <label for="token">Token</label>
    <input type="password" id="token" name="token" autocomplete="off" autofocus required>
    <button type="submit">View my insights</button>
  </form>
  <p style="margin-top: 16px; font-size: 12px; color: var(--muted);">
    Admin? Use <a href="/admin/login">/admin/login</a> instead.
  </p>
</div>
{% endblock %}
